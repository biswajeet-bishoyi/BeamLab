{
  "name": "beamworks-workspace",
  "private": true,
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "prepare": "husky",
    "publish-packages": "changeset publish"
  },
  "lint-staged": {
    "*.{js,ts,tsx,jsx,json,md}": [
      "prettier --write"
    ],
    "*.{js,ts,tsx,jsx}": [
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^24.13.2",
    "eslint": "^8.57.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "turbo": "^2.10.3",
    "typescript": "^6.0.3"
  }
}
