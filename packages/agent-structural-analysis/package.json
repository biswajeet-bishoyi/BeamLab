{
  "name": "@beamlab/agent-structural-analysis",
  "version": "1.0.0",
  "description": "BeamLab Structural Analysis Engineering Agent",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
