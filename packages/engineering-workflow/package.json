{
  "name": "@beamlab/engineering-workflow",
  "version": "1.0.0",
  "private": true,
  "description": "BeamLab Engineering Workflow Orchestrator",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
