{
  "name": "@beamlab/agent-design",
  "version": "1.0.0",
  "private": true,
  "description": "BeamLab Structural Design Agent",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@beamlab/agent-framework": "workspace:*",
    "@beamlab/engineering-reasoning": "workspace:*",
    "@beamlab/context-engine": "workspace:*",
    "@beamlab/knowledge-platform": "workspace:*",
    "@beamlab/policy-engine": "workspace:*",
    "@beamlab/resource-manager": "workspace:*"
  },
  "devDependencies": {
    "@beamlab/config": "workspace:*",
    "typescript": "^5.3.3",
    "tsup": "^8.0.1",
    "vitest": "^1.2.1"
  }
}
